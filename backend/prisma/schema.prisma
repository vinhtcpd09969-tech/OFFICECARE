generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}

model vai_tro {
  id          Int          @id @default(autoincrement()) @db.SmallInt
  ma_vai_tro  String       @db.VarChar(20)
  ten_vai_tro String       @db.VarChar(50)
  nguoi_dung  nguoi_dung[]
}

model nguoi_dung {
  id                    Int                     @id @default(autoincrement())
  ho_ten                String                  @db.VarChar(150)
  email                 String                  @unique @db.VarChar(255)
  so_dien_thoai         String?                 @db.VarChar(20)
  mat_khau_hash         String                  @db.VarChar(255)
  vai_tro_id            Int                     @db.SmallInt
  trang_thai            String                  @default("hoat_dong") @db.VarChar(20)
  anh_dai_dien          String?
  cuoc_hen_tao          cuoc_hen[]              @relation("cuoc_hen_nguoi_tao")
  cuoc_hen              cuoc_hen[]
  giao_dich_thanh_toan  giao_dich_thanh_toan[]
  ho_so_chuyen_gia      ho_so_chuyen_gia?
  lich_truc_nhan_su     lich_truc_nhan_su[]
  vai_tro               vai_tro                 @relation(fields: [vai_tro_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  nhat_ky_buoi_dieu_tri nhat_ky_buoi_dieu_tri[]
  refresh_tokens        refresh_tokens[]
  tam_giu_cho           tam_giu_cho[]
  thong_bao             thong_bao[]
  bai_viet              bai_viet[]
  danh_gia_nhan_su      danh_gia_nhan_su[]
}

model ho_so_chuyen_gia {
  id                 Int        @id @default(autoincrement())
  nguoi_dung_id      Int        @unique
  so_nam_kinh_nghiem Int?
  bang_cap_chung_chi String?
  mo_ta              String?
  the_manh           String[]   @default([])
  nguoi_dung         nguoi_dung @relation(fields: [nguoi_dung_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model lich_truc_nhan_su {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nhan_su_id   Int
  ngay_truc    DateTime        @db.Date
  ca_truc      String          @db.VarChar(20)
  gio_bat_dau  DateTime        @db.Time(6)
  gio_ket_thuc DateTime        @db.Time(6)
  trang_thai   String          @default("hoat_dong") @db.VarChar(20)
  phong_id     Int?
  nguoi_dung   nguoi_dung      @relation(fields: [nhan_su_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  phong        phong_lam_viec? @relation(fields: [phong_id], references: [id], onUpdate: NoAction)
}

model khach_hang {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ho_ten              String                @db.VarChar(150)
  email               String?               @unique @db.VarChar(255)
  mat_khau_hash       String?               @db.VarChar(255)
  so_dien_thoai       String?               @db.VarChar(20)
  dia_chi             String?
  ngay_sinh           DateTime?             @db.Date
  gioi_tinh           String?               @db.VarChar(10)
  trang_thai          String                @default("hoat_dong") @db.VarChar(20)
  diem_uy_tin         Int                   @default(100)
  ngay_dong_y_dieu_khoan DateTime?          @db.Timestamptz(6)
  cuoc_hen            cuoc_hen[]
  danh_gia_goi_dich_vu danh_gia_goi_dich_vu[]
  danh_gia_nhan_su    danh_gia_nhan_su[]
  hoa_don             hoa_don[]
  phac_do_dieu_tri    phac_do_dieu_tri[]
  refresh_tokens      refresh_tokens[]
  thong_bao           thong_bao[]
}

model nhat_ky_buoi_dieu_tri {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cuoc_hen_id    String          @unique @db.Uuid
  nguoi_tao_id   Int
  vas_truoc      Int?
  vas_sau        Int?
  chan_doan      String?
  chong_chi_dinh String?
  ghi_chu        String?
  ngay_tao       DateTime        @default(now()) @db.Timestamptz(6)
  chi_dinh_buoi  chi_dinh_buoi[]
  cuoc_hen       cuoc_hen        @relation(fields: [cuoc_hen_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  nguoi_dung     nguoi_dung      @relation(fields: [nguoi_tao_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model chi_dinh_buoi {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nhat_ky_id            String                @db.Uuid
  goi_dich_vu_id        String?               @db.Uuid
  ghi_chu               String?
  // Snapshot cấu hình gói tại đúng thời điểm bác sĩ chỉ định — số buổi là một chỉ định lâm sàng,
  // admin sửa gói về sau không được phép âm thầm đổi liệu trình/giá đã tư vấn cho khách.
  tong_so_buoi_tu_van   Int?
  don_gia_tu_van        BigInt?
  // Đánh dấu chỉ định này đã dẫn tới phác đồ nào (set khi khách thanh toán/kích hoạt) — nguồn
  // xác thực duy nhất để nối ngược 1 phác đồ về đúng ca khám đã chỉ định ra nó, và để biết 1 chỉ
  // định đã được kích hoạt hay còn "chờ kích hoạt". KHÔNG dùng cuoc_hen.phac_do_dieu_tri_id của
  // ca khám cho việc này — field đó chỉ dành cho buổi điều trị thật, gán cho ca khám sẽ làm hỏng
  // cách tính trạng thái thanh toán của ca khám đó (xem lịch sử sửa createInvoiceDirect).
  phac_do_dieu_tri_id   String?               @db.Uuid
  goi_dich_vu           goi_dich_vu?          @relation(fields: [goi_dich_vu_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  nhat_ky_buoi_dieu_tri nhat_ky_buoi_dieu_tri @relation(fields: [nhat_ky_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  phac_do_dieu_tri      phac_do_dieu_tri?     @relation(fields: [phac_do_dieu_tri_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model cuoc_hen {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  khach_hang_id         String                 @db.Uuid
  nhan_su_id            Int?
  goi_dich_vu_id        String?                @db.Uuid
  phac_do_dieu_tri_id   String?                @db.Uuid
  so_thu_tu_buoi        Int?
  ngay_gio_bat_dau      DateTime               @db.Timestamptz(6)
  ngay_gio_ket_thuc     DateTime               @db.Timestamptz(6)
  loai                  String                 @db.VarChar(20)
  trang_thai            String                 @default("cho_xac_nhan") @db.VarChar(20)
  ghi_chu_khach_hang    String?
  phong_id              Int?
  ghi_chu_noi_bo        String?
  anh_dinh_kem_url      String?
  thoi_gian_huy         DateTime?              @db.Timestamptz(6)
  nguoi_tao_id          Int?
  goi_dich_vu           goi_dich_vu?           @relation(fields: [goi_dich_vu_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  khach_hang            khach_hang             @relation(fields: [khach_hang_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  nguoi_dung            nguoi_dung?            @relation(fields: [nhan_su_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  nguoi_dung_tao        nguoi_dung?            @relation("cuoc_hen_nguoi_tao", fields: [nguoi_tao_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  phac_do_dieu_tri      phac_do_dieu_tri?      @relation(fields: [phac_do_dieu_tri_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  phong                 phong_lam_viec?        @relation(fields: [phong_id], references: [id], onUpdate: NoAction)
  danh_gia_goi_dich_vu danh_gia_goi_dich_vu[]
  danh_gia_nhan_su    danh_gia_nhan_su[]
  hoa_don               hoa_don[]
  nhat_ky_buoi_dieu_tri nhat_ky_buoi_dieu_tri?
}

model goi_dich_vu {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ten_goi           String             @db.VarChar(200)
  loai_goi          String             @db.VarChar(20)
  tong_so_buoi      Int                @default(1)
  thoi_luong_phut   Int                @default(30)
  don_gia           BigInt
  don_gia_theo_buoi BigInt
  trang_thai        String             @default("hoat_dong") @db.VarChar(20)
  anh_goi           String?
  anh_gallery       String[]           @default([])
  danh_muc_goi_id   String?            @db.Uuid
  muc_tieu          String?
  quy_trinh         String?
  han_su_dung_mac_dinh_ngay Int?
  chi_dinh_buoi     chi_dinh_buoi[]
  cuoc_hen          cuoc_hen[]
  danh_muc_goi      danh_muc_goi?      @relation(fields: [danh_muc_goi_id], references: [id], onUpdate: NoAction)
  phac_do_dieu_tri  phac_do_dieu_tri[]
  tam_giu_cho       tam_giu_cho[]
  danh_gia_goi_dich_vu danh_gia_goi_dich_vu[]
}

model danh_muc_goi {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ten_danh_muc     String        @db.VarChar(150)
  mo_ta            String?
  loai_goi_ap_dung String        @default("LIEU_TRINH") @db.VarChar(20)
  goi_dich_vu      goi_dich_vu[]
}

model phac_do_dieu_tri {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  khach_hang_id   String      @db.Uuid
  goi_dich_vu_id  String      @db.Uuid
  tong_so_buoi    Int
  so_buoi_da_dung Int         @default(0)
  trang_thai      String      @default("cho_kich_hoat") @db.VarChar(20)
  ngay_kich_hoat  DateTime?   @db.Date
  han_su_dung     DateTime?   @db.Date
  cuoc_hen        cuoc_hen[]
  hoa_don         hoa_don[]
  chi_dinh_buoi   chi_dinh_buoi[]
  goi_dich_vu     goi_dich_vu @relation(fields: [goi_dich_vu_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  khach_hang      khach_hang  @relation(fields: [khach_hang_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model hoa_don {
  id                       String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  khach_hang_id            String                 @db.Uuid
  phac_do_dieu_tri_id      String?                @db.Uuid
  cuoc_hen_id              String?                @db.Uuid
  tong_tien_goc            BigInt                 @default(0)
  hinh_thuc_thanh_toan_goi String?                @db.VarChar(20)
  ti_le_giam_gia_goi       Int?                   @default(0)
  voucher_id               String?                @db.Uuid
  so_tien_giam_voucher     BigInt?                @default(0)
  tong_tien_phai_tra       BigInt
  so_tien_da_tra           BigInt                 @default(0)
  trang_thai               String                 @default("chua_thanh_toan") @db.VarChar(30)
  ghi_chu                  String?
  // Phí khám lâm sàng tại đúng thời điểm chốt hóa đơn gói (được miễn hoặc khấu trừ vào gói).
  // Bắt buộc snapshot: hóa đơn khám được miễn bị ghi đè tong_tien_phai_tra = 0, nên nếu không lưu
  // ở đây thì lúc hủy gói không còn cách nào biết đã miễn cho khách bao nhiêu để truy thu lại.
  phi_kham_ap_dung         BigInt                 @default(0)
  ngay_tao                 DateTime               @default(now()) @db.Timestamptz(6)
  giao_dich_thanh_toan     giao_dich_thanh_toan[]
  cuoc_hen                 cuoc_hen?              @relation(fields: [cuoc_hen_id], references: [id], onUpdate: NoAction)
  khach_hang               khach_hang             @relation(fields: [khach_hang_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  phac_do_dieu_tri         phac_do_dieu_tri?      @relation(fields: [phac_do_dieu_tri_id], references: [id], onUpdate: NoAction)
  khuyen_mai_voucher       khuyen_mai_voucher?    @relation(fields: [voucher_id], references: [id], onUpdate: NoAction)
}

model giao_dich_thanh_toan {
  id                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hoa_don_id             String     @db.Uuid
  so_tien                BigInt
  loai_giao_dich         String     @db.VarChar(20)
  phuong_thuc            String     @db.VarChar(20)
  ma_tham_chieu          String?    @db.VarChar(100)
  nhan_vien_thuc_hien_id Int
  ngay_giao_dich         DateTime   @default(now()) @db.Timestamptz(6)
  chi_tiet               Json?
  hoa_don                hoa_don    @relation(fields: [hoa_don_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  nguoi_dung             nguoi_dung @relation(fields: [nhan_vien_thuc_hien_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model khuyen_mai_voucher {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ma_code            String    @unique @db.VarChar(50)
  ten_chien_dich     String    @default("") @db.VarChar(150)
  loai_giam_gia      String    @db.VarChar(20)
  gia_tri_giam       BigInt
  giam_toi_da        BigInt?
  don_hang_toi_thieu BigInt    @default(0)
  ngay_bat_dau       DateTime  @db.Timestamptz(6)
  ngay_het_han       DateTime? @db.Timestamptz(6)
  so_luong_gioi_han  Int?
  dang_kich_hoat     Boolean   @default(true)
  yeu_cau_thanh_toan String[] @default(["tat_ca"])
  hoa_don            hoa_don[]
}

model danh_gia_goi_dich_vu {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  khach_hang_id  String      @db.Uuid
  goi_dich_vu_id String      @db.Uuid
  cuoc_hen_id    String?     @db.Uuid
  so_sao         Int
  nhan_xet       String?
  ngay_tao       DateTime    @default(now()) @db.Timestamptz(6)
  ngay_cap_nhat  DateTime    @default(now()) @db.Timestamptz(6)
  khach_hang     khach_hang  @relation(fields: [khach_hang_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  goi_dich_vu    goi_dich_vu @relation(fields: [goi_dich_vu_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  cuoc_hen       cuoc_hen?   @relation(fields: [cuoc_hen_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([khach_hang_id, goi_dich_vu_id])
}

model danh_gia_nhan_su {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  khach_hang_id String     @db.Uuid
  nhan_su_id    Int
  cuoc_hen_id   String?    @db.Uuid
  so_sao        Int
  nhan_xet      String?
  ngay_tao      DateTime   @default(now()) @db.Timestamptz(6)
  ngay_cap_nhat DateTime   @default(now()) @db.Timestamptz(6)
  khach_hang    khach_hang @relation(fields: [khach_hang_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  nguoi_dung    nguoi_dung @relation(fields: [nhan_su_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  cuoc_hen      cuoc_hen?  @relation(fields: [cuoc_hen_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([khach_hang_id, nhan_su_id])
}

model otp_codes {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String   @db.VarChar(255)
  otp        String   @db.VarChar(6)
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

model refresh_tokens {
  id            Int         @id @default(autoincrement())
  nguoi_dung_id Int?
  khach_hang_id String?     @db.Uuid
  token         String
  expires_at    DateTime    @db.Timestamp(6)
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  khach_hang    khach_hang? @relation(fields: [khach_hang_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  nguoi_dung    nguoi_dung? @relation(fields: [nguoi_dung_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model thong_bao {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nguoi_dung_id   Int?
  khach_hang_id   String?     @db.Uuid
  tieu_de         String      @db.VarChar(200)
  noi_dung        String
  loai            String      @default("he_thong") @db.VarChar(30)
  da_doc          Boolean     @default(false)
  thoi_gian_tao   DateTime    @default(now()) @db.Timestamp(6)
  lien_ket        String?     @db.VarChar(255)
  tham_chieu_id   String?     @db.VarChar(50)
  tham_chieu_loai String?     @db.VarChar(50)
  khach_hang      khach_hang? @relation(fields: [khach_hang_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  nguoi_dung      nguoi_dung? @relation(fields: [nguoi_dung_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model phong_lam_viec {
  id                Int                 @id @default(autoincrement())
  ten_phong         String              @db.VarChar(100)
  ma_phong          String?             @db.VarChar(20)
  loai_phong        String              @db.VarChar(50)
  suc_chua          Int                 @default(1)
  trang_thai        String              @default("san_sang") @db.VarChar(20)
  mo_ta             String?
  cuoc_hen          cuoc_hen[]
  lich_truc_nhan_su lich_truc_nhan_su[]
}

model thiet_bi {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ma_thiet_bi  String    @unique @db.VarChar(50)
  ten_thiet_bi String    @db.VarChar(150)
  ngay_mua     DateTime? @db.Date
  trang_thai   String    @default("san_sang") @db.VarChar(20)
  ghi_chu      String?
}

model tam_giu_cho {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id        String       @unique @db.VarChar(100)
  ngay_gio_bat_dau  DateTime     @db.Timestamptz(6)
  ngay_gio_ket_thuc DateTime     @db.Timestamptz(6)
  nhan_su_id        Int?
  goi_dich_vu_id    String?      @db.Uuid
  thoi_gian_het_han DateTime     @db.Timestamptz(6)
  thoi_gian_tao     DateTime?    @default(now()) @db.Timestamptz(6)
  khach_hang_id     String?      @db.Uuid
  so_dien_thoai     String?
  goi_dich_vu       goi_dich_vu? @relation(fields: [goi_dich_vu_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  nguoi_dung        nguoi_dung?  @relation(fields: [nhan_su_id], references: [id], onUpdate: NoAction)

  @@index([thoi_gian_het_han], map: "idx_tam_giu_cho_het_han")
}

model bai_viet {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tieu_de          String     @db.VarChar(200)
  slug             String     @unique @db.VarChar(255)
  tom_tat          String     @db.Text
  noi_dung         String     @db.Text
  anh_bia          String?    @db.Text
  danh_muc         String     @db.VarChar(30)
  trang_thai       String     @default("nhap") @db.VarChar(20)
  meta_title       String?    @db.VarChar(70)
  meta_description String?    @db.VarChar(160)
  meta_keywords    String?    @db.VarChar(255)
  luot_xem         Int        @default(0)
  nguoi_viet_id    Int
  ngay_dang        DateTime?  @db.Timestamptz(6)
  ngay_tao         DateTime   @default(now()) @db.Timestamptz(6)
  ngay_cap_nhat    DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  nguoi_dung       nguoi_dung @relation(fields: [nguoi_viet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([trang_thai, ngay_dang])
  @@index([danh_muc])
}
